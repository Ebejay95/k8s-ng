# terraform.tfvars.example – Beispiel-Konfiguration

project_name = "navosec"
environment  = "prod"
region       = "eu-west-1"
cloud_provider = "aws"

# ──────────────────────────────────────────────────────────────────
# NETZWERK
# ──────────────────────────────────────────────────────────────────

vpc_cidr     = "10.0.0.0/16"
subnet_cidr  = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
enable_nat_gateway = true
enable_dns   = true

# ──────────────────────────────────────────────────────────────────
# KUBERNETES
# ──────────────────────────────────────────────────────────────────

kubernetes_version = "1.28"
cluster_endpoint_public_access = false
cluster_endpoint_public_access_cidrs = []  # Leer = Private Cluster (nur Bastion)

# ──────────────────────────────────────────────────────────────────
# NODE POOLS
# ──────────────────────────────────────────────────────────────────

default_node_pool = {
  name           = "default"
  machine_type   = "t3.2xlarge"
  min_size       = 2
  max_size       = 10
  disk_size_gb   = 100
  disk_type      = "gp3"
  node_labels    = { "workload" = "general" }
  node_taints    = []
}

gpu_node_pool = {
  enabled        = true
  name           = "gpu"
  machine_type   = "g4dn.xlarge"
  min_size       = 0
  max_size       = 5
  gpu_count      = 1
  disk_size_gb   = 150
  node_labels    = { "workload" = "gpu", "accelerator" = "nvidia-t4" }
  node_taints    = [{ key = "gpu", value = "true", effect = "NoSchedule" }]
}

observability_node_pool = {
  enabled        = false
  name           = "observability"
  machine_type   = "t3.xlarge"
  min_size       = 0
  max_size       = 3
  disk_size_gb   = 200
  node_labels    = { "workload" = "observability" }
  node_taints    = [{ key = "observability", value = "true", effect = "NoSchedule" }]
}

# ──────────────────────────────────────────────────────────────────
# NODE OS
# ──────────────────────────────────────────────────────────────────

node_os        = "talos"
node_os_version = "v1.6.0"

# ──────────────────────────────────────────────────────────────────
# STORAGE
# ──────────────────────────────────────────────────────────────────

enable_ebs_csi  = true
enable_s3_csi   = true
s3_bucket_name  = ""  # Auto-generiert: navosec-prod-s3-<random>

enable_rds_postgres = true
postgres_instance_class = "db.t3.medium"
postgres_allocated_storage = 100
postgres_backup_retention_days = 30
postgres_multi_az = true

# ──────────────────────────────────────────────────────────────────
# DNS
# ──────────────────────────────────────────────────────────────────

dns_zone_name = "meinedomain.de"
create_dns_zone = false  # Verwende externe DNS-Zone

# ──────────────────────────────────────────────────────────────────
# LOAD BALANCER & INGRESS
# ──────────────────────────────────────────────────────────────────

load_balancer_type = "nlb"
enable_acme_tls = true
acme_email = "admin@meinedomain.de"

# ──────────────────────────────────────────────────────────────────
# IAM & RBAC
# ──────────────────────────────────────────────────────────────────

enable_irsa = true
oidc_provider_enabled = true

# ──────────────────────────────────────────────────────────────────
# SECURITY
# ──────────────────────────────────────────────────────────────────

enable_cluster_autoscaling = true
enable_network_policy = true
cni_plugin = "calico"
enable_pod_security_policy = false  # PSA stattdessen
enable_encryption_at_rest = true
enable_audit_logging = true

# ──────────────────────────────────────────────────────────────────
# BASTION
# ──────────────────────────────────────────────────────────────────

enable_bastion = true
bastion_machine_type = "t3.micro"
bastion_allowed_ssh_cidrs = ["YOUR_OFFICE_IP/32"]  # Ersetze durch deine IP

# ──────────────────────────────────────────────────────────────────
# TAGS
# ──────────────────────────────────────────────────────────────────

common_tags = {
  "Project"     = "navosec"
  "ManagedBy"   = "terraform"
  "Component"   = "kubernetes"
  "Environment" = "prod"
  "CostCenter"  = "engineering"
}

additional_tags = {}

# ──────────────────────────────────────────────────────────────────
# BACKUP & DISASTER RECOVERY
# ──────────────────────────────────────────────────────────────────

enable_backups = true
backup_retention_days = 30
backup_schedule = "0 2 * * *"
